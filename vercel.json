{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd frontend/magazine-web && npm ci",
  "buildCommand": "cd frontend/magazine-web && npm run vercel-build",
  "outputDirectory": "frontend/magazine-web/dist/magazine-web/browser",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
